# skywatch environment variables
# All keys are OPTIONAL. The app works out of the box with Open-Meteo and ipapi.co (both free, no key).
# Copy this file to .env and fill in any keys you have.
#
# PRIVACY NOTE: Never commit .env to version control.

# ─────────────────────────────────────────────
# FORECAST PROVIDERS
# ─────────────────────────────────────────────

# Open-Meteo — FREE, no key required
# https://open-meteo.com/en/terms
# Provides: ECMWF IFS 7-day global forecast, WMO weather codes
# Free tier: Unlimited for open-source / non-commercial use
# Fallback: Always active. No configuration needed.
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# OpenWeatherMap — free tier 1,000 calls/day
# Get key: https://home.openweathermap.org/api_keys
# Provides: Current conditions, 5-day 3-hour forecast, air quality
# Free tier: 1,000 calls/day, 60 calls/minute
# Fallback: Provider disabled, returns mock data
OPENWEATHERMAP_API_KEY=

# NVIDIA NGC API Key — for Earth-2 / FourCastNet NIM inference
# Get key: https://ngc.nvidia.com/setup/api-key
# Provides: AI-native global weather forecasting (FourCastNet, CorrDiff)
# Docs: https://docs.api.nvidia.com/nim/reference/nvidia-fourcastnet
# Free tier: $0.018 per forecast call (credit-based)
# Fallback: Provider stub returns realistic mock data with a TODO comment
NVIDIA_NGC_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# ─────────────────────────────────────────────
# GEOLOCATION
# ─────────────────────────────────────────────

# ipapi.co — IP to city-level geolocation
# Get key: https://ipapi.co/#pricing
# Provides: Country, region, city, lat/lon from IP (city-level only)
# Free tier: 1,000 requests/day without key; 30,000/month with free key
# Fallback: Works without key up to free-tier limit; returns null on exhaustion
# Privacy: IP is NEVER logged. Used ephemerally for a single request.
IPINFO_TOKEN=

# ─────────────────────────────────────────────
# WEBCAM / CAMERA SOURCES
# ─────────────────────────────────────────────

# Windy Webcams API v3
# Get key: https://api.windy.com/webcams (requires account)
# Provides: 50,000+ public webcams globally, thumbnails, metadata, ToS-compliant
# ToS: https://api.windy.com/webcams/docs#terms
# Free tier: 500 calls/day on free plan
# Fallback: Camera grid shows empty state with informational message
WINDY_API_KEY=

# ─────────────────────────────────────────────
# BACKEND SERVICE CONFIGURATION
# ─────────────────────────────────────────────

# FastAPI host/port
API_HOST=0.0.0.0
API_PORT=8000

# CORS: comma-separated allowed origins for the API
# In production, restrict this to your frontend domain
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ─────────────────────────────────────────────
# FRONTEND CONFIGURATION
# ─────────────────────────────────────────────

# Next.js public API base URL (accessible from the browser)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Default location for hero/demo (no privacy implication — this is a UI default)
# Format: lat,lon,display_name
NEXT_PUBLIC_DEFAULT_LOCATION=23.8103,90.4125,Dhaka

# ─────────────────────────────────────────────
# FUTURE / RESERVED (not active in v0.1)
# ─────────────────────────────────────────────

# Google MetNet (v0.3 — paid, enterprise access required)
# Docs: https://cloud.google.com/blog/topics/developers-practitioners/metnet-3-google-deepminds-weather-model
GOOGLE_WEATHER_API_KEY=

# Sentry DSN for error monitoring (optional)
SENTRY_DSN=
